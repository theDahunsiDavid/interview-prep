# Interview Prep — Environment Variables
#
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ── Active provider (Groq, free tier) ──────────────────────────────
# Sign up at https://console.groq.com
# Create an API key under "API Keys"
# Free tier: generous rate limits, no credit card required
GROQ_API_KEY=

# ── Optional: Google Gemini (for provider switching) ───────────────
# Sign up at https://aistudio.google.com
# Create an API key under "Get API Key"
# Free tier: no credit card required
# GOOGLE_GENERATIVE_AI_API_KEY=

# ── Optional: Vercel AI Gateway (for provider switching) ───────────
# Sign up at https://vercel.com
# Create an API key under "AI Gateway"
# AI_GATEWAY_API_KEY=
